{
  "navigationFallback": {
    "rewrite": "/404.html",
    "exclude": ["/images/*", "/icons/*", "/*.css", "/*.js", "/sitemap.xml", "/index.xml"]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/404.html",
      "statusCode": 404
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
